# chokectl hosts file — one entry per line, # comments allowed.
# Format:  <name>  <base-url>
# `chokectl --hosts=PATH` overrides; otherwise CHOKECTL_HOSTS env var or
# ./chokectl.hosts in the current directory.
#
# Auth uses $CHOKE_USER / $CHOKE_PASS (defaults: admin / ebpf-soc-demo).
# Every host in this file must accept the same credentials.

